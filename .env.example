# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=AgentPlatform

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://agentplatform:agentplatform@localhost:5432/agentplatform?schema=public

# Redis (matches docker-compose.yml defaults)
REDIS_URL=redis://localhost:6379

# Auth (Phase 1)
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# Email (Phase 1) — dev mode logs to console when unset
# RESEND_API_KEY=
EMAIL_FROM=noreply@agentplatform.local

# Lead Finder (admin-only) — Serper.dev Google search API (2,500 free queries)
# SERPER_API_KEY=

# Seed super admin (optional — run npm run db:seed)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=change-me-strong-password

# Stripe (Phase 3)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# PayPal (Phase 3)
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=

# Object storage (Phase 4)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Observability (Phase 4)
# SENTRY_DSN=
