generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  support
  admin
  super_admin
}

enum UserStatus {
  active
  suspended
  deleted
}

enum AgentStatus {
  active
  coming_soon
  disabled
}

enum PlanTier {
  free
  pro
}

enum BillingInterval {
  month
  year
}

enum WebsiteVerificationStatus {
  pending
  verified
  failed
}

enum WebsiteVerificationMethod {
  dns_txt
  meta_tag
  html_file
}

enum SeoScanStatus {
  queued
  running
  completed
  failed
  canceled
}

enum SeoScanType {
  full
  sitemap
  robots
  schema
  links
  index
}

enum SeoIssueCategory {
  sitemap
  robots
  schema
  broken_link
  indexing
  other
}

enum SeoIssueSeverity {
  critical
  warning
  info
}

enum PodLeadStatus {
  draft
  sent
  replied
  interested
}

/// Phase 0 stub — kept for health check compatibility
model SystemMeta {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(100)
  value     String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("system_meta")
}

model Organization {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(255)
  slug         String   @unique @db.VarChar(100)
  billingEmail String?  @map("billing_email") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  users    User[]
  websites Website[]

  @@map("organizations")
}

model User {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String?    @map("organization_id") @db.Uuid
  email          String     @unique @db.VarChar(255)
  emailVerified  DateTime?  @map("email_verified_at") @db.Timestamptz(6)
  passwordHash   String?    @map("password_hash") @db.VarChar(255)
  name           String?    @db.VarChar(255)
  role           UserRole   @default(user)
  status         UserStatus @default(active)
  deletedAt      DateTime?  @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization            Organization?            @relation(fields: [organizationId], references: [id])
  accounts                Account[]
  sessions                Session[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  agentActivations        AgentActivation[]
  websites                Website[]
  usagePeriods            UsagePeriod[]
  seoScans                SeoScan[]
  podLeads                PodLead[]
  auditLogsAsActor        AuditLog[]               @relation("AuditActor")
  auditLogsAsTarget       AuditLog[]               @relation("AuditTarget")

  @@index([organizationId])
  @@map("users")
}

model Account {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  type              String   @db.VarChar(50)
  provider          String   @db.VarChar(50)
  providerAccountId String   @map("provider_account_id") @db.VarChar(255)
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?  @db.VarChar(50)
  scope             String?  @db.VarChar(255)
  id_token          String?  @db.Text
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id             String   @id @default(uuid()) @db.Uuid
  sessionToken   String   @unique @map("session_token") @db.VarChar(255)
  userId         String   @map("user_id") @db.Uuid
  expires        DateTime @db.Timestamptz(6)
  impersonatorId String?  @map("impersonator_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String   @db.VarChar(255)
  token      String   @unique @db.VarChar(255)
  expires    DateTime @db.Timestamptz(6)

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Agent {
  id          String      @id @default(uuid()) @db.Uuid
  slug        String      @unique @db.VarChar(50)
  name        String      @db.VarChar(100)
  description String      @db.Text
  status      AgentStatus @default(coming_soon)
  sortOrder   Int         @default(0) @map("sort_order")
  iconKey     String      @default("bot") @map("icon_key") @db.VarChar(50)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  plans        AgentPlan[]
  activations  AgentActivation[]
  usagePeriods UsagePeriod[]

  @@map("agents")
}

model AgentPlan {
  id              String          @id @default(uuid()) @db.Uuid
  agentId         String          @map("agent_id") @db.Uuid
  tier            PlanTier
  name            String          @db.VarChar(100)
  priceCents      Int             @default(0) @map("price_cents")
  currency        String          @default("USD") @db.Char(3)
  billingInterval BillingInterval @default(month) @map("billing_interval")
  limits          Json            @default("{}")
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, tier])
  @@map("agent_plans")
}

model AgentActivation {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  agentId     String   @map("agent_id") @db.Uuid
  eventType   String   @map("event_type") @db.VarChar(100)
  eventRefId  String?  @map("event_ref_id") @db.Uuid
  activatedAt DateTime @default(now()) @map("activated_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
  @@map("agent_activations")
}

model Website {
  id                 String                     @id @default(uuid()) @db.Uuid
  userId             String                     @map("user_id") @db.Uuid
  organizationId     String?                    @map("organization_id") @db.Uuid
  domain             String                     @db.VarChar(255)
  displayName        String?                    @map("display_name") @db.VarChar(255)
  verificationStatus WebsiteVerificationStatus  @default(pending) @map("verification_status")
  verificationMethod WebsiteVerificationMethod? @map("verification_method")
  verificationToken  String?                    @map("verification_token") @db.VarChar(255)
  verifiedAt         DateTime?                  @map("verified_at") @db.Timestamptz(6)
  isActive           Boolean                    @default(true) @map("is_active")
  deletedAt          DateTime?                  @map("deleted_at") @db.Timestamptz(6)
  createdAt          DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id])
  seoScans     SeoScan[]
  seoIssues    SeoIssue[]

  @@unique([userId, domain])
  @@index([userId])
  @@map("websites")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  targetUserId String?  @map("target_user_id") @db.Uuid
  action       String   @db.VarChar(100)
  metadata     Json     @default("{}")
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor  User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  target User? @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([targetUserId, createdAt(sort: Desc)])
  @@index([actorUserId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model FeatureFlag {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(100)
  enabled   Boolean  @default(false)
  agentId   String?  @map("agent_id") @db.Uuid
  metadata  Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("feature_flags")
}

model UsagePeriod {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  agentId   String   @map("agent_id") @db.Uuid
  period    String   @db.Char(7)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent    Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  counters UsageCounter[]

  @@unique([userId, agentId, period])
  @@map("usage_periods")
}

model UsageCounter {
  id            String   @id @default(uuid()) @db.Uuid
  usagePeriodId String   @map("usage_period_id") @db.Uuid
  metric        String   @db.VarChar(50)
  count         Int      @default(0)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  usagePeriod UsagePeriod @relation(fields: [usagePeriodId], references: [id], onDelete: Cascade)

  @@unique([usagePeriodId, metric])
  @@map("usage_counters")
}

model SeoScan {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @map("user_id") @db.Uuid
  websiteId     String        @map("website_id") @db.Uuid
  status        SeoScanStatus @default(queued)
  scanType      SeoScanType   @default(full) @map("scan_type")
  pagesLimit    Int           @map("pages_limit")
  pagesCrawled  Int           @default(0) @map("pages_crawled")
  startedAt     DateTime?     @map("started_at") @db.Timestamptz(6)
  completedAt   DateTime?     @map("completed_at") @db.Timestamptz(6)
  errorMessage  String?       @map("error_message") @db.Text
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  website Website        @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  pages   SeoScanPage[]
  issues  SeoIssue[]
  report  SeoReport?

  @@index([websiteId, createdAt(sort: Desc)])
  @@index([userId, status])
  @@map("seo_scans")
}

model SeoScanPage {
  id          String    @id @default(uuid()) @db.Uuid
  scanId      String    @map("scan_id") @db.Uuid
  url         String    @db.Text
  statusCode  Int?      @map("status_code")
  crawledAt   DateTime? @map("crawled_at") @db.Timestamptz(6)
  metaRobots  String?   @map("meta_robots") @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  scan SeoScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@map("seo_scan_pages")
}

model SeoIssue {
  id              String           @id @default(uuid()) @db.Uuid
  scanId          String           @map("scan_id") @db.Uuid
  websiteId       String           @map("website_id") @db.Uuid
  pageUrl         String?          @map("page_url") @db.Text
  category        SeoIssueCategory
  severity        SeoIssueSeverity
  code            String           @db.VarChar(50)
  message         String           @db.Text
  fixInstruction  String           @map("fix_instruction") @db.Text
  metadata        Json?
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  scan    SeoScan   @relation(fields: [scanId], references: [id], onDelete: Cascade)
  website Website   @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([scanId, category])
  @@index([websiteId, createdAt(sort: Desc)])
  @@map("seo_issues")
}

model SeoReport {
  id         String   @id @default(uuid()) @db.Uuid
  scanId     String   @unique @map("scan_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  websiteId  String   @map("website_id") @db.Uuid
  summary    Json     @default("{}")
  storageUrl String?  @map("storage_url") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  scan SeoScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@map("seo_reports")
}

model PodLead {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  email     String        @db.VarChar(255)
  name      String?       @db.VarChar(255)
  shopName  String?       @map("shop_name") @db.VarChar(255)
  shopUrl   String?       @map("shop_url") @db.Text
  niche     String?       @db.VarChar(255)
  notes     String?       @db.Text
  status    PodLeadStatus @default(draft)
  subject   String?       @db.Text
  bodyHtml  String?       @map("body_html") @db.Text
  bodyText  String?       @map("body_text") @db.Text
  sentAt    DateTime?     @map("sent_at") @db.Timestamptz(6)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([userId, status])
  @@map("pod_leads")
}
